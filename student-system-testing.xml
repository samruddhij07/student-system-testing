<project name="student-system-testing" xmlns:sonar="antlib:org.sonar.ant">
	<property file="build.properties" />

	<property name="sonar.host.url" value="http://10.131.103.244:9000" />
    <property name="sonar.projectKey" value="student-system-testing" />
    <property name="sonar.projectName" value="Student Grading System" />
    <property name="sonar.projectVersion" value="1.0" />
    <property name="sonar.sources" value="${srcdir}" />
    <property name="sonar.java.binaries" value="${builddir}/${classdir}" />
    <property name="sonar.junit.reportPaths" value="test-reports" />
	<property name="sonar.jar.path" value="${ant.home}/lib/sonarqube-ant-task-2.7.1.1951.jar" />
	
	<target name="compile">
		<mkdir dir = "${builddir}/${classdir}" />
		<javac srcdir="${srcdir}" destdir="${builddir}/${classdir}" />
	</target>

	<target name="test" depends="compile">
		<mkdir dir="test-reports" />
		<junit printsummary="yes" fork="true" haltonfailure="yes">
			<classpath>
				<pathelement path="${builddir}/${classdir}"/>
				<fileset dir="lib" includes="*.jar" />
			</classpath>
		
			<formatter type="xml"/>

			<batchtest todir="test-reports">
				<fileset dir="${srcdir}">
					<include name="**/*Test.java" />
				</fileset>
			</batchtest>
		</junit>
	</target>

	<target name="check-sonar-jar">
		<echo message="Checking sonar-ant-task.jar file..."/>
		<available file="${sonar.jar.path}" property="sonar.jar.present"/>
		<fail unless="sonar.jar.present">
			################################################################
			ALERT: sonar-ant-task.jar file not found in ${ant.home}/lib
			Download it from the official website of SonarQube Distribution
			################################################################
		</fail>
		<echo message="Success: sonar-ant-task.jar file found at ${sonar.jar.path}" />
	</target>

	<target name="sonar" depends="compile, check-sonar-jar">
        <taskdef uri="antlib:org.sonar.ant" resource="org/sonar/ant/antlib.xml" />
		<sonar:sonar />
    </target>

</project>
